# Real-Time Stock Analysis Platform - Environment Variables

# Application
APP_NAME="Real-Time Stock Analysis Platform"
APP_VERSION="1.0.0"
DEBUG=True
ENVIRONMENT=development

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Database - PostgreSQL
DATABASE_URL=postgresql://stockuser:stockpass@localhost:5432/stockanalysis
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300
REDIS_MAX_CONNECTIONS=50

# Security
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8501","http://localhost:8000"]

# External APIs
# Yahoo Finance (no key needed)
YAHOO_FINANCE_ENABLED=True

# Finnhub (optional)
FINNHUB_API_KEY=your_finnhub_api_key_here
FINNHUB_ENABLED=False

# News API
NEWS_API_KEY=your_news_api_key_here
NEWS_API_ENABLED=False

# Notifications
# Email (SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key_here
EMAIL_FROM=noreply@stockanalysis.com
EMAIL_ENABLED=False

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
SMS_ENABLED=False

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ENABLED=False

# WebSocket
WS_HEARTBEAT_INTERVAL=30
WS_MAX_CONNECTIONS=1000
WS_MESSAGE_QUEUE_SIZE=100

# Real-Time Data
PRICE_UPDATE_INTERVAL=5
MARKET_DATA_CACHE_TTL=60
ENABLE_REAL_TIME_STREAMING=True

# Machine Learning
ML_MODEL_PATH=./ml_models/saved_models
ML_PREDICTION_CACHE_TTL=300
ENABLE_PREDICTIONS=True

# Backtesting
BACKTEST_INITIAL_CAPITAL=100000
BACKTEST_POSITION_SIZE=0.1

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Monitoring
SENTRY_DSN=your_sentry_dsn_here
SENTRY_ENABLED=False
PROMETHEUS_ENABLED=True

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=./logs/app.log

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=False

# Feature Flags
ENABLE_PAPER_TRADING=True
ENABLE_SOCIAL_FEATURES=False
ENABLE_ADVANCED_ANALYTICS=True